# --- Application ---
APP_NAME=moonite
DEBUG=false
API_HOST=0.0.0.0
# 宿主机访问 API 的端口（docker-compose 映射到容器 8000）
HOST_PORT=8000
# 本地直接运行 uvicorn 时监听端口
API_PORT=8000

# asyncpg 连接串
# 宿主机运行 uvicorn、Postgres 用 compose 映射端口时：
DATABASE_URL=postgresql+asyncpg://postgres:test@127.0.0.1:5432/moonite
# 使用 docker compose up 同时启动 api 时须改为（主机名 db）：
# DATABASE_URL=postgresql+asyncpg://postgres:test@db:5432/moonite

# --- PostgreSQL（docker-compose 中 db 服务）---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=test
POSTGRES_DB=moonite
POSTGRES_PORT=5432